# Variables del buzón de feedback (configurar en Vercel → Settings → Environment Variables).
# NO commitear los valores reales. Estas son solo de referencia.

# URL del proyecto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Service role key de Supabase (Settings → API → service_role secret).
# ¡SECRETA! Solo se usa en el servidor (funciones /api), nunca en el navegador.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Contraseña para entrar al buzón privado (la inventas tú).
BUZON_PASSWORD=una-clave-larga-que-elijas
